:set prompt "λ: "

:set -fwarn-incomplete-patterns
-- defer errors til runtime and then load module as normal
-- maybe also consider -fbreak-on-error
:set -fdefer-type-errors
:set -fno-warn-type-defaults

-- require hoogle installed locally
-- :def hoogle \x -> Control.Applicative.pure $ ":!hoogle \"" ++ x ++ "\""
-- :def doc \x -> Control.Applicative.pure $ ":!hoogle --info \"" ++ x ++ "\""

-- require package pretty-simple
:def pretty \_ -> Control.Applicative.pure ("import Text.Pretty.Simple\n:set -interactive-print Text.Pretty.Simple.pPrint")
:def no-pretty \_ -> Control.Applicative.pure (":set -interactive-print System.IO.print")
